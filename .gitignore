# Python bytecode / build metadata
__pycache__/
*.py[cod]
*.egg-info/

# Incomplete downloads
*.part

# Built HF datasets (regenerable from analysis/*subset*.json)
/mvr_dataset/
/crossview_dataset/
*.tmp/
*.tmp

# Generated converter output: pre-subset master pools (regenerable via
# convert_crossview.py in <1s). The eval *subset* json files are tracked; these
# *_qa.json pools are not.
/analysis/crossview_*_qa.json

# AgiBot HF tar-tree cache (regenerated by fetch_agibot_videos.py)
/analysis/.agibot_tree_cache.json

# Large fetched media & external release data — licensed/regenerable, do not commit
/crossview-release-annotations/
/Video-R1/src/r1-v/Evaluation/CVBench/

# Regenerable analysis outputs, logs, media (rebuilt by analyze_failures.py /
# curate_failure_examples.py / make_slides_v2.py from the tracked eval JSONs)
/analysis/logs/
/analysis/download_subset.log
/analysis/failure_examples/
/analysis/slides_v2_figs/
# large per-question failure dumps (12M/685K); the curated digest stays tracked
/analysis/crossview_meva1033_out/qwen3vl_failures.md
/analysis/crossview_meva1033_out/internvl3_failures.md

# Regenerable slide decks (binary) + eval-rerun contamination backups
*.pptx
*.contaminated*.bak

# Benchmark run outputs (regenerable via bench/run_bench.py)
/bench/results/

# Claude Code local config / runtime (per-user, not shared)
/.claude/

# Stray root-level screenshot (not referenced anywhere; do not commit)
/image.png
